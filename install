#!/usr/bin/env bash

set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTBOT="$DOTFILES_DIR/dotbot/bin/dotbot"

# Ask for sudo once up front and keep the ticket fresh during bootstrap.
sudo -v
while true; do
  sudo -n true
  sleep 60
  kill -0 "$$" || exit
done 2>/dev/null &
SUDO_KEEPALIVE_PID=$!
trap 'kill "$SUDO_KEEPALIVE_PID"' EXIT

if ! command -v brew >/dev/null 2>&1; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

git -C "$DOTFILES_DIR" submodule update --init --recursive

"$DOTBOT" -d "$DOTFILES_DIR" --plugin-dir "$DOTFILES_DIR/dotbot-plugins/dotbot-brewfile" -c "$DOTFILES_DIR/install.conf.yaml" "$@"
